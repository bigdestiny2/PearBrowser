<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base app theme. Compose handles its own dark colors; this is just
         what the Android system shows before Activity.setContent runs. -->
    <style name="Theme.PearBrowser" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/pear_bg</item>
        <item name="android:statusBarColor">@color/pear_bg</item>
        <item name="android:navigationBarColor">@color/pear_surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
    </style>
</resources>
