{
  "expo": {
    "name": "PearBrowser",
    "slug": "pear-browser",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pearbrowser.app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        },
        "NSCameraUsageDescription": "Scan QR codes to open hyper:// links"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.pearbrowser.app",
      "usesCleartextTraffic": true
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0",
            "newArchEnabled": true
          },
          "android": {
            "minSdkVersion": 29,
            "newArchEnabled": true
          }
        }
      ]
    ],
    "scheme": "pearbrowser",
    "extra": {
      "eas": {
        "projectId": "f84eafc6-f7c2-4489-b81e-479410ab3340"
      }
    },
    "owner": "bigdestiny22s-organization"
  }
}
